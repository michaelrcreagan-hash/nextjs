{
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$HOME/.claude\" && cp -rf \"$CLAUDE_PROJECT_DIR/.claude/cbt-framework\" \"$HOME/.claude/\""
          }
        ]
      }
    ]
  }
}
