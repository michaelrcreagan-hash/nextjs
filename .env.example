# ── Optional API Keys ──────────────────────────────────────────────────────────
# All keys are optional. The dashboard works without them using free/public data.
# Copy this file to .env.local and fill in any keys you have.

# FRED (Federal Reserve Economic Data)
# Free at https://fredaccount.stlouisfed.org/login/secure/
# Used for: Net Fed Liquidity = WALCL − WTREGEN − RRPONTSYD
FRED_API_KEY=

# Glassnode
# Free tier at https://studio.glassnode.com — Standard plan needed for MVRV
# Used for: real MVRV ratio, on-chain realized BTC price
# Without this key, MVRV is computed from Binance price / estimated realized price
GLASSNODE_API_KEY=

# Polygon.io
# Free Starter tier at https://polygon.io — 5 req/min, 15-min delayed
# Used for: higher-quality aggregated options chains (IBIT, MSTR, VIX)
# Without this key, Yahoo Finance options data is used automatically (free, no key)
POLYGON_API_KEY=
