// v7 Combined: Auto BO/PB
//@version=6
strategy("v7 Combined",
 overlay=true,
 default_qty_type=
 strategy.percent_of_equity,
 default_qty_value=5,
 commission_value=0.1,
 slippage=1)

// Config
md=input.string("Auto",
 "Mode",
 options=["Auto","BO","PB"],
 group="Cfg")

// BO Params
cb=input.int(5,"BO CD",
 minval=1,
 group="Breakout")
asl=input.float(2.0,
 "BO Stop",
 step=0.5,
 group="Breakout")
atp=input.float(3.0,
 "BO Tgt",
 step=0.5,
 group="Breakout")
ath=input.float(1.3,
 "ATR% Thr",
 step=0.1,
 group="Breakout")
rl=input.int(50,"RSI L",
 minval=30,maxval=60,
 group="Breakout")
ru=input.int(70,"RSI H",
 minval=60,maxval=85,
 group="Breakout")

// PB Params
cp=input.int(5,"PB CD",
 minval=1,
 group="Pullback")
fl=input.int(60,"Fib Lk",
 minval=20,
 group="Pullback")
ft=input.float(4.0,
 "Fib Tol",
 step=0.5,
 group="Pullback")
km=input.float(2.0,
 "Kelt M",
 step=0.5,
 group="Pullback")
psl=input.float(1.5,
 "PB Stop",
 step=0.5,
 group="Pullback")

// Shared
utf=input.bool(true,
 "UpTrend",
 group="Filters")
mx=input.int(3,"Max Pos",
 minval=1,
 group="Risk")

// Indicators
a=ta.atr(14)
ap=a/close*100
aa=ta.sma(ap,20)
rsi=ta.rsi(close,14)
e21=ta.ema(close,21)
e50=ta.ema(close,50)
e200=ta.ema(close,200)

// Trend
tk=not utf or
 (close>e50 and e50>e200)

// BO Signal
acs=ap>ath*aa
rcs=rsi>rl and rsi<ru
bo=acs and rcs and tk

// PB Signal
ph=ta.highest(high,fl)
pl=ta.lowest(low,fl)
fr=ph-pl
f38=ph-0.382*fr
f61=ph-0.618*fr
f78=ph-0.786*fr
ke=ta.ema(close,20)
ak=ta.atr(10)
klw=ke-km*ak
fd=math.abs(close-f61)
 /close*100
akc=close<=klw*1.02
pb=fd<=ft and akc and tk

// Auto Mode
ab=md=="Auto" and
 ap>ath*1.5*aa
apb=md=="Auto" and not ab
ub=md=="BO" or ab
up=md=="PB" or apb

// Position Count
pc=strategy.opentrades

// Cooldown
var int lb1=0
var int lb2=0
bok=(bar_index-lb1)>=cb
pok=(bar_index-lb2)>=cp
if bo and bok
 lb1:=bar_index
if pb and pok
 lb2:=bar_index

// Entries
sz=strategy.position_size==0
if ub and bo and bok and
 pc<mx
 sl=close-asl*a
 tp=close+atp*a
 strategy.entry("BO",
  strategy.long)
 strategy.exit("BX","BO",
  stop=sl,limit=tp)
if up and pb and pok and
 pc<mx
 s1=f78-0.5*a
 s2=close-psl*a
 sl=math.max(s1,s2)
 strategy.entry("PB",
  strategy.long)
 strategy.exit("PX","PB",
  stop=sl,limit=f38)

// Visuals
plotshape(bo and ub,"B",
 shape.triangleup,
 location.belowbar,
 color.green,size.small)
plotshape(pb and up,"P",
 shape.diamond,
 location.belowbar,
 color.blue,size.small)
plot(e21,"E21",
 color=color.orange)
plot(e50,"E50",
 color=color.blue)

// Dashboard
var table d=table.new(
 position.top_right,2,7,
 bgcolor=color.new(
  color.black,20),
 frame_width=1)
if barstate.islast
 ms=md=="Auto"?
  (ab?"A:BO":"A:PB"):md
 table.cell(d,0,0,"M",
  text_color=color.white,
  text_size=size.small)
 table.cell(d,1,0,ms,
  text_color=color.yellow,
  text_size=size.small)
 table.cell(d,0,1,"ATR%",
  text_color=color.white,
  text_size=size.small)
 table.cell(d,1,1,
  str.tostring(ap,"#.##"),
  text_color=color.white,
  text_size=size.small)
 table.cell(d,0,2,"RSI",
  text_color=color.white,
  text_size=size.small)
 table.cell(d,1,2,
  str.tostring(rsi,"#."),
  text_color=color.white,
  text_size=size.small)
 table.cell(d,0,3,"FD%",
  text_color=color.white,
  text_size=size.small)
 table.cell(d,1,3,
  str.tostring(fd,"#.##"),
  text_color=color.white,
  text_size=size.small)
 table.cell(d,0,4,"POS",
  text_color=color.white,
  text_size=size.small)
 table.cell(d,1,4,
  str.tostring(pc)+"/"
  +str.tostring(mx),
  text_color=color.white,
  text_size=size.small)
 table.cell(d,0,5,"TRD",
  text_color=color.white,
  text_size=size.small)
 tc=tk?color.green:color.red
 table.cell(d,1,5,
  tk?"UP":"DN",
  text_color=tc,
  text_size=size.small)
 table.cell(d,0,6,"v7",
  text_color=color.gray,
  text_size=size.tiny)
